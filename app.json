{
  "expo": {
    "name": "coffee-demo-testing",
    "slug": "coffee-demo-testing",
    "scheme": "coffee-demo-testing",

    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.exponathan.coffeedemotesting"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.exponathan.coffeedemotesting"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "CoffeeTracker",
              "displayName": "Coffee Bar",
              "description": "Today's coffee at a glance, with quick-log buttons and shortcuts into the app.",
              "ios": {
                "supportedFamilies": [
                  "systemSmall",
                  "systemMedium",
                  "systemLarge",
                  "accessoryCircular"
                ],
                "configuration": {
                  "title": "Coffee Bar",
                  "description": "Pick the drink the +1 button logs.",
                  "parameters": {
                    "defaultDrink": {
                      "title": "Default drink",
                      "type": "enum",
                      "values": [
                        { "name": "Espresso", "value": "espresso" },
                        { "name": "Drip", "value": "drip" },
                        { "name": "Latte", "value": "latte" }
                      ],
                      "default": "espresso"
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    ]
  }
}
